{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Debug API",
      "program": "${workspaceFolder}/src/app.js",
      "restart": true,
      "runtimeExecutable": "node",
      "runtimeArgs": ["--watch"],
      "console": "integratedTerminal",
      "envFile": "${workspaceFolder}/.env",
      "skipFiles": ["<node_internals>/**", "node_modules/**"]
    }
  ]
}
